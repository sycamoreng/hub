{"file":"staff-B1McO5DT.js","mappings":";;;;;;;;;;;;;;;;;;;AACyC,mBAAA;AACzC,UAAM,QAAQ,IAAW,EAAE;AAC3B,UAAM,cAAc,IAAW,EAAE;AACjC,UAAM,SAAS,IAAI,EAAE;AACrB,UAAM,eAAe,IAAI,KAAK;AAC9B,UAAM,UAAU,IAAI,IAAI;AAUxB,UAAM,WAAW,SAAS,MAAM;AAC9B,YAAM,IAAI,OAAO,MAAM,KAAA,EAAO,YAAA;AAC9B,aAAO,MAAM,MAAM,OAAO,CAAA,MAAK;AAC7B,cAAM,SAAS,aAAa,UAAU,SAAS,EAAE,aAAa,SAAS,aAAa;AACpF,YAAI,CAAC,OAAQ,QAAO;AACpB,YAAI,CAAC,EAAG,QAAO;AACf,eAAO,EAAE,UAAU,YAAA,EAAc,SAAS,CAAC,KAAK,EAAE,KAAK,cAAc,SAAS,CAAC,KAAK,EAAE,MAAM,YAAA,EAAc,SAAS,CAAC;AAAA,MACtH,CAAC;AAAA,IACH,CAAC;AAED,aAAS,SAAS,MAAc;AAC9B,aAAO,KAAK,MAAM,GAAG,EAAE,IAAI,OAAK,EAAE,CAAC,CAAC,EAAE,KAAK,EAAE,EAAE,MAAM,GAAG,CAAC,EAAE,YAAA;AAAA,IAC7D;;;mBAIOA,eAAAC,WAAA,EAAA,OAAM,uBAAmB,MAAA,CAAA,yQAQRC,MAAA,MAAA,CAAM;AAC4D,YAAAC,mBAAA,wBAAA,EAAA,MAAK,YAAQ,MAAA,OAAA,CAAA;gHAEhFD,MAAA,YAAA,CAAY,oBAAZA,MAAA,YAAA,GAAY,KAAA,kBAAZA,MAAA,YAAA,GAAY,KAAA,CAAA,IAAA,cAAA,EAAA,mCAAA;AAEPE,oBAAAF,MAAA,WAAA,IAAL,MAAC;sCAA8B,SAAO,EAAE,IAAI,wCAF5CA,MAAA,YAAA,CAAY,oBAAZA,MAAA,YAAA,GAEsC,EAAE,IAAI,kBAF5CA,MAAA,YAAA,GAEsC,EAAE,IAAI,CAAA,IAAA,cAAA,MAAKG,eAAA,EAAE,IAAI;;;UAI/DH,MAAA,OAAA,GAAO;;MACF,WAAAA,MAAA,QAAA,EAAS,WAAM,GAAA;;;;AAERE,sBAAAF,MAAA,QAAA,IAAL,MAAC;sPAEV,SAAS,EAAE,SAAS,CAAA,wFAG8BG,eAAA,EAAE,SAAS,sDAChBA,eAAA,EAAE,IAAI;cAExC,EAAE,aAAa,MAAI;oEAA+B,EAAE,YAAY,IAAI,CAAA,SAAA;AAAA;;;2FAG5E,QAAI,UAAY,EAAE,KAAK,EAAA,qCAAuCA,eAAA,EAAE,KAAK;AAEhE,cAAA,EAAE,WAAS;+EAA2C,EAAE,UAAU,IAAI,CAAA,QAAA;AAAA;;;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_unref","_ssrRenderComponent","_ssrRenderList","_ssrInterpolate"],"sources":["../../../../pages/staff.vue"],"sourcesContent":["<script setup lang=\"ts\">\nconst { fetchStaff, fetchDepartments } = useCompanyData()\nconst staff = ref<any[]>([])\nconst departments = ref<any[]>([])\nconst search = ref('')\nconst selectedDept = ref('All')\nconst loading = ref(true)\n\nonMounted(async () => {\n  try {\n    const [s, d] = await Promise.all([fetchStaff(), fetchDepartments()])\n    staff.value = s\n    departments.value = d\n  } finally { loading.value = false }\n})\n\nconst filtered = computed(() => {\n  const q = search.value.trim().toLowerCase()\n  return staff.value.filter(s => {\n    const deptOk = selectedDept.value === 'All' || s.departments?.name === selectedDept.value\n    if (!deptOk) return false\n    if (!q) return true\n    return s.full_name.toLowerCase().includes(q) || s.role.toLowerCase().includes(q) || s.email.toLowerCase().includes(q)\n  })\n})\n\nfunction initials(name: string) {\n  return name.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase()\n}\n</script>\n\n<template>\n  <div class=\"max-w-7xl mx-auto\">\n    <div class=\"mb-8\">\n      <h1 class=\"section-title\">Staff Directory</h1>\n      <p class=\"section-subtitle\">Meet the people who make Sycamore thrive.</p>\n    </div>\n\n    <div class=\"card p-4 mb-6 flex flex-col sm:flex-row gap-3\">\n      <div class=\"relative flex-1\">\n        <input v-model=\"search\" type=\"text\" placeholder=\"Search by name, role, or email...\" class=\"input pl-10\" />\n        <div class=\"absolute left-3 top-1/2 -translate-y-1/2 text-slate-400\"><SidebarIcon name=\"search\" /></div>\n      </div>\n      <select v-model=\"selectedDept\" class=\"input sm:w-56\">\n        <option value=\"All\">All departments</option>\n        <option v-for=\"d in departments\" :key=\"d.id\" :value=\"d.name\">{{ d.name }}</option>\n      </select>\n    </div>\n\n    <div v-if=\"loading\" class=\"text-slate-400\">Loading staff...</div>\n    <div v-else-if=\"filtered.length === 0\" class=\"text-slate-400\">No staff match your filters.</div>\n    <div v-else class=\"grid sm:grid-cols-2 lg:grid-cols-3 gap-4\">\n      <article v-for=\"s in filtered\" :key=\"s.id\" class=\"card card-hover p-5 flex gap-4\">\n        <div class=\"w-14 h-14 rounded-full bg-gradient-to-br from-sycamore-400 to-sycamore-700 text-white flex items-center justify-center font-bold text-lg flex-shrink-0\">\n          {{ initials(s.full_name) }}\n        </div>\n        <div class=\"min-w-0 flex-1\">\n          <h3 class=\"font-semibold text-slate-900 truncate\">{{ s.full_name }}</h3>\n          <div class=\"text-sm text-slate-600 truncate\">{{ s.role }}</div>\n          <div class=\"text-xs text-slate-500 mt-1\">\n            <span v-if=\"s.departments?.name\" class=\"badge badge-green\">{{ s.departments.name }}</span>\n          </div>\n          <div class=\"text-xs text-slate-500 mt-2 truncate\">\n            <a :href=\"`mailto:${s.email}`\" class=\"hover:text-sycamore-700\">{{ s.email }}</a>\n          </div>\n          <div v-if=\"s.locations\" class=\"text-xs text-slate-400 mt-0.5\">{{ s.locations.city }}</div>\n        </div>\n      </article>\n    </div>\n  </div>\n</template>\n"],"version":3}